# Backend selection:
# - auto: use windows backend on Windows, macos backend on macOS, otherwise mock
# - mock: run the full API chain without a real iEterm client
# - windows: connect to the real Windows desktop client
# - macos: connect to the real macOS desktop client
IETERM_AUTOMATION_BACKEND=auto

# Mobile web console access token. Change this before exposing the service
# through Tailscale or any remote access method.
IETERM_MOBILE_ACCESS_TOKEN=change-this-token

# Real macOS client configuration
IETERM_MAC_APP_NAME=iEterm Mac版
IETERM_MAC_PROCESS_NAME=

# Real Windows client configuration
IETERM_WINDOW_TITLE=iEterm
IETERM_WINDOW_TITLE_RE=.*iEterm.*
IETERM_EXECUTABLE_PATH=
IETERM_PYWINAUTO_BACKEND=uia

# Query command templates. Replace these with the exact syntax used by your
# iEterm deployment if the defaults are not correct in your environment.
IETERM_AVAILABILITY_COMMAND_TEMPLATE=AV {origin} {destination} {departure_date}
IETERM_INTERNATIONAL_FARE_COMMAND_TEMPLATE=XS FSD {origin}{destination}{airline_part}

# Enable guarded auto-login only after you have configured the login controls.
IETERM_AUTO_LOGIN_ENABLED=false
IETERM_USERNAME=
IETERM_PASSWORD=
IETERM_USERNAME_CONTROL=
IETERM_PASSWORD_CONTROL=
IETERM_SUBMIT_CONTROL=

# Text markers used to distinguish login / expired / ready states.
IETERM_LOGIN_KEYWORDS=登录,login,sign in,password
IETERM_SESSION_EXPIRED_KEYWORDS=超时,expired,session expired,relogin,重新登录
